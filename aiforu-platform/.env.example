# Required for the contact form (src/app/api/contact/route.ts) to deliver
# submissions by email instead of silently discarding them. Create a Resend
# account at https://resend.com, generate an API key, and set these as
# Environment Variables in the Vercel project settings (not committed here).

# Resend API key.
RESEND_API_KEY=

# Where contact form submissions are delivered. Must be the email address
# used to sign up for Resend, unless a custom sending domain is verified.
CONTACT_TO_EMAIL=

# Optional. Once the aiforui.org domain is verified in Resend, set this to a
# branded sender, e.g. "AIforU&I Contact Form <contact@aiforui.org>". Until
# then the route falls back to Resend's shared onboarding sender, which only
# delivers to the account's own email.
RESEND_FROM_EMAIL=
